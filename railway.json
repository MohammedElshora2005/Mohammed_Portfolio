{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "buildCommand": "cd backend && npm install",
      "startCommand": "cd backend && node server.js"
    }
  },
  "deploy": {
    "startCommand": "cd backend && node server.js",
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1
  }
}